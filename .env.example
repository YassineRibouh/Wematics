# App
APP_NAME=Wematics Archive Dashboard
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Storage
DATABASE_URL=sqlite:///./data/wematics.db
MIGRATIONS_PATH=./migrations
ARCHIVE_BASE_PATH=./downloads
TRANSFER_TEMP_BASE_PATH=./data/transfer_tmp
LOCAL_SCAN_CACHE_SECONDS=60

# Optional Postgres profile for docker-compose
POSTGRES_USER=wematics
POSTGRES_PASSWORD=change-me
POSTGRES_DB=wematics

# Wematics API
WEMATICS_API_KEY=
DEFAULT_TIMEZONE=local
REMOTE_DATES_TTL_SECONDS=300
REMOTE_RETRY_ATTEMPTS=4
REMOTE_RETRY_BASE_DELAY_SECONDS=1.0

# FTP
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=
FTP_TIMEOUT_SECONDS=30
FTP_PASSIVE_MODE=true
FTP_BASE_PATH=/wematics
FTP_CONFLICT_BASE_PATH=/wematics_conflicts
FTP_READ_ONLY_PATHS=/images,/images safe
FTP_MAX_RETRIES=4
FTP_RETRY_BASE_DELAY_SECONDS=1.0

# Workers
WORKER_POLL_INTERVAL_SECONDS=2.0
SCHEDULER_POLL_INTERVAL_SECONDS=30.0
DOWNLOAD_CONCURRENCY=3
UPLOAD_CONCURRENCY=2
TRANSFER_CONCURRENCY=8

# Alerts
NO_NEW_DATA_ALERT_MINUTES=180
FTP_BACKLOG_ALERT_THRESHOLD=500
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_KIND=generic
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_COOLDOWN_MINUTES=30

# CSV analysis
CSV_ANALYSIS_CACHE_ENABLED=true
